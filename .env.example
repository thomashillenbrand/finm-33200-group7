# Required: OpenAI API key for the agent's LLM calls.
OPENAI_API_KEY=

# Required for `python -m data_pull`: your WRDS account username.
WRDS_USERNAME=

# Optional: identifies you to SEC EDGAR (fair-access policy requires a UA).
# Defaults to a generic project string if unset; override with your name + email.
# SEC_USER_AGENT="Your Name your@email.com"
